<!DOCTYPE html>
<html>
<head>
  <title>NBM Billing</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: #f5f6f8;
    }

    .brand-navbar {
      background: linear-gradient(90deg, #0f172a, #1e293b);
      box-shadow: 0 2px 12px rgba(0,0,0,0.18);
      padding-top: 12px;
      padding-bottom: 12px;
    }

    .brand-wrap {
      display: flex;
      align-items: center;
      gap: 16px;
      text-decoration: none;
    }

    /* 🔥 STRUCTURAL FIX: Made the box wider and taller */
    .brand-logo-shell {
      background: rgba(255,255,255,0.96);
      border-radius: 14px;
      width: 130px; 
      height: 95px; 
      padding: 0; /* Removed padding to let the logo fill it */
      box-shadow: 0 6px 18px rgba(0,0,0,0.22);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      flex-shrink: 0;
    }

    /* 🔥 LOGO FIX: Magnified the logo massively to kill invisible space */
    .brand-logo {
      width: 100%;
      height: 100%;
      object-fit: contain;
      transform: scale(1.75); 
      transform-origin: center center;
    }

    .brand-text {
      display: flex;
      flex-direction: column;
      line-height: 1.05;
    }

    .brand-title {
      color: #ffffff;
      font-size: 1.95rem;
      font-weight: 900;
      margin: 0;
      letter-spacing: 0.2px;
      text-shadow: 0 1px 2px rgba(0,0,0,0.22);
    }

    .brand-subtitle {
      color: #dbeafe;
      font-size: 0.95rem;
      margin: 3px 0 0 0;
      font-weight: 600;
    }

    .nav-btns {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .nav-btns .btn {
      font-weight: 600;
      border-radius: 10px;
      padding-left: 12px;
      padding-right: 12px;
      transition: all 0.2s ease;
    }

    .btn-primary {
      background: #2563eb !important;
      border: none;
    }

    .btn-light {
      background: #ffffff;
    }

    .page-shell {
      padding-top: 24px;
      padding-bottom: 30px;
    }

    .card,
    .table,
    .alert {
      border-radius: 12px !important;
    }

    @media (max-width: 991px) {
      .brand-logo-shell {
        width: 85px;
        height: 65px;
      }

      .brand-title {
        font-size: 1.45rem;
      }

      .brand-subtitle {
        font-size: 0.78rem;
      }
    }
  </style>
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark brand-navbar px-3">
  <a class="navbar-brand brand-wrap" href="/dashboard">
    <div class="brand-logo-shell">
      <img src="/images/logo.png" alt="Logo" class="brand-logo">
    </div>

    <div class="brand-text">
      <span class="brand-title">NBM </span>
      <span class="brand-subtitle">Medical Billing & Inventory System</span>
    </div>
  </a>

  <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
    <span class="navbar-toggler-icon"></span>
  </button>

  <div class="collapse navbar-collapse justify-content-end" id="mainNavbar">
    <div class="nav-btns mt-3 mt-lg-0">

      <a href="/dashboard"
         class="btn btn-sm <%= active === 'dashboard' ? 'btn-primary' : 'btn-light' %>">
         Dashboard
      </a>

      <a href="/products"
         class="btn btn-sm <%= active === 'products' ? 'btn-primary' : 'btn-light' %>">
        Inventory
      </a>

      <a href="/bill/create"
         class="btn btn-sm <%= active === 'create' ? 'btn-primary' : 'btn-light' %>">
         Create Bill
      </a>

      <a href="/bills"
         class="btn btn-sm <%= active === 'bills' ? 'btn-primary' : 'btn-light' %>">
         Bills
      </a>

      <a href="/products/expiry"
         class="btn btn-sm <%= active === 'expiry' ? 'btn-primary' : 'btn-light' %>">
         Expiry
      </a>

      <a href="/products/low-stock"
         class="btn btn-sm <%= active === 'low' ? 'btn-primary' : 'btn-light' %>">
         Low Stock
      </a>

      <a href="/settings"
         class="btn btn-sm <%= active === 'settings' ? 'btn-primary' : 'btn-light' %>">
         Settings
      </a>

      <a href="/logout" class="btn btn-danger btn-sm">Logout</a>

    </div>
  </div>
</nav>

<div class="container page-shell">

  <% if (success_msg && success_msg.length > 0) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <%= success_msg[0] %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <% if (error_msg && error_msg.length > 0) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <%= error_msg[0] %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>