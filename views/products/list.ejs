<%- include('../partials/header') %>

<form method="GET" action="/products" class="row g-2 mb-3">
  <div class="col-md-6">
    <input 
      type="text" 
      name="search" 
      class="form-control" 
      placeholder="Search by product name, manufacturer, or batch"
      value="<%= search || '' %>"
    >
  </div>
  <div class="col-auto">
    <button class="btn btn-primary">Search</button>
    <a href="/products" class="btn btn-secondary">Reset</a>
  </div>
</form>
<div class="d-flex flex-wrap gap-2 mb-3">
  <a href="/products/add" class="btn btn-primary">+ Add Product</a>
  <a href="/products/expiry" class="btn btn-warning">Expiry Products</a>
  <a href="/products/low-stock" class="btn btn-danger">Low Stock</a>
</div>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Products</h3>
    
  </div>

  <div class="table-responsive">
    <table class="table table-bordered table-striped">
      <thead class="table-dark">
        <tr>
          <th>Name</th>
          <th>Batch</th>
          <th>Expiry</th>
          <th>Qty</th>
          <th>Price</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>
        <% products.forEach(p=> { %>
          <tr>
            <td>
              <%= p.name %>
            </td>
            <td>
              <%= p.batchNo %>
            </td>
            <td>
              <%= p.expiryDate ? p.expiryDate.toDateString() : '' %>
            </td>
            <td>
              <span class="badge bg-<%= p.quantity < 10 ? 'danger' : 'success' %>">
                <%= p.quantity %>
              </span>
            </td>
            <td>₹<%= p.sellingPrice %>
            </td>
            <td>
              <a href="/products/edit/<%= p._id %>" class="btn btn-warning btn-sm">Edit</a>
              <a href="/products/delete/<%= p._id %>" class="btn btn-danger btn-sm"
                onclick="return confirm('Are you sure you want to delete this product?')">
                Delete
              </a>
            </td>
          </tr>
          <% }) %>
      </tbody>
    </table>
  </div>

  <%- include('../partials/footer') %>